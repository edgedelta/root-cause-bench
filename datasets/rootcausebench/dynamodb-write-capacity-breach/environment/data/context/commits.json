  {
    "sha": "7e2c9b41a0f5d3c8b6e4f10927ad3c5e8f1b6a04",
    "author": "wei.zhang",
    "timestamp": "2026-06-22T16:38:20Z",
    "message": "#platform Simplify memstore persistence path",
    "files_changed": [
      "pkg/memstore/dynamo_writer.go"
    ],
    "diff": "--- a/pkg/memstore/dynamo_writer.go\n+++ b/pkg/memstore/dynamo_writer.go\n@@ -41,24 +41,17 @@ func (w *Writer) Flush(ctx context.Context, items []Item) error {\n-\t// Group pending items into BatchWriteItem requests (<=25 per batch)\n-\t// so each flush consumes one write unit per item but amortizes calls\n-\t// and lets the SDK coalesce capacity across the batch.\n-\tfor _, chunk := range chunkItems(items, 25) {\n-\t\treqs := make([]types.WriteRequest, 0, len(chunk))\n-\t\tfor _, it := range chunk {\n-\t\t\treqs = append(reqs, types.WriteRequest{\n-\t\t\t\tPutRequest: &types.PutRequest{Item: it.AV()},\n-\t\t\t})\n-\t\t}\n-\t\tif _, err := w.db.BatchWriteItem(ctx, &dynamodb.BatchWriteItemInput{\n-\t\t\tRequestItems: map[string][]types.WriteRequest{w.table: reqs},\n-\t\t}); err != nil {\n-\t\t\treturn err\n-\t\t}\n-\t}\n-\treturn nil\n+\t// Write each item directly; clearer control flow and per-item error\n+\t// attribution than the previous batch grouping.\n+\tfor _, it := range items {\n+\t\tif _, err := w.db.PutItem(ctx, &dynamodb.PutItemInput{\n+\t\t\tTableName: aws.String(w.table),\n+\t\t\tItem:      it.AV(),\n+\t\t}); err != nil {\n+\t\t\treturn err\n+\t\t}\n+\t}\n+\treturn nil\n }"
  },
