    "diff": "--- a/ai-memory-svc/internal/compaction/compact.go\n+++ b/ai-memory-svc/internal/compaction/compact.go\n@@ -18,9 +18,12 @@ func Compact(turns []Turn) []Turn {\n-\tout := dedupe(turns)\n-\treturn summarizeOld(out)\n+\tout := dedupe(turns)\n+\tout = summarizeOld(out)\n+\t// keep the most recent window verbatim, summarize the tail\n+\tif len(out) > maxWindow {\n+\t\tout = append(out[:maxWindow], rollup(out[maxWindow:])...)\n+\t}\n+\treturn out\n }"
